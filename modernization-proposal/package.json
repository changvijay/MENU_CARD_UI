{
  "name": "modern-admin-panel",
  "version": "2.0.0",
  "dependencies": {
    // Core React Stack
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.8.0",

    // State Management
    "zustand": "^4.3.6", // Lightweight global state
    "@tanstack/react-query": "^4.28.0", // Server state management

    // Form Handling
    "react-hook-form": "^7.43.7",
    "@hookform/resolvers": "^3.0.0",
    "zod": "^3.21.4", // Schema validation

    // UI Component Libraries
    "@radix-ui/react-dialog": "^1.0.3",
    "@radix-ui/react-dropdown-menu": "^2.0.4",
    "@radix-ui/react-select": "^1.2.1",
    "@radix-ui/react-checkbox": "^1.0.3",
    "@radix-ui/react-slider": "^1.1.1",
    "@radix-ui/react-switch": "^1.0.2",
    "@radix-ui/react-toast": "^1.1.3",
    "cmdk": "^0.2.0", // Command menu/search

    // Data Visualization  
    "recharts": "^2.5.0",
    "@nivo/core": "^0.83.0",
    "@nivo/line": "^0.83.0",

    // Table Management
    "@tanstack/react-table": "^8.7.9",
    "@tanstack/react-virtual": "^3.0.0-beta.54",

    // Animation & Interactions
    "framer-motion": "^10.10.0",
    "react-spring": "^9.6.1",

    // Icons & Assets
    "lucide-react": "^0.220.0",
    "@heroicons/react": "^2.0.17",

    // Utilities
    "clsx": "^1.2.1", // Conditional classes
    "date-fns": "^2.29.3", // Date utilities
    "react-dropzone": "^14.2.3", // File uploads
    "react-hotkeys-hook": "^4.4.0", // Keyboard shortcuts

    // Dev Experience
    "@types/react": "^18.0.28",
    "@types/react-dom": "^18.0.11",
    "typescript": "^5.0.2",
    "vite": "^4.2.0",
    "autoprefixer": "^10.4.14",
    "tailwindcss": "^3.3.0",
    "postcss": "^8.4.21",

    // Testing
    "@testing-library/react": "^14.0.0",
    "@testing-library/jest-dom": "^5.16.5",
    "vitest": "^0.29.7",
    "msw": "^1.2.1", // Mock service worker

    // Performance Monitoring
    "web-vitals": "^3.3.1",
    "@sentry/react": "^7.46.0"
  },

  "devDependencies": {
    // Code Quality
    "eslint": "^8.37.0",
    "prettier": "^2.8.7",
    "husky": "^8.0.3",
    "lint-staged": "^13.2.0",

    // Build Tools
    "vite-plugin-eslint": "^1.8.1",
    "vite-plugin-pwa": "^0.14.4",

    // Bundle Analysis
    "vite-bundle-analyzer": "^0.7.0"
  },

  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx}\"",
    "analyze": "vite-bundle-analyzer",
    "prepare": "husky install"
  }
}